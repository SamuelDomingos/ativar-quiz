generator client {
    provider = "prisma-client"
    output   = "../src/generated"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        String    @id @default(uuid())
    name      String?
    email     String?   @unique()
    password  String?
    avatar    String?
    createdAt DateTime  @default(now())
    updatedAt DateTime?

    quizzes   Quiz[]
    games     Game[]
    players   Player[]
}

model Quiz {
    id          String     @id @default(uuid())
    title       String
    description String?
    coverUrl    String?
    userId      String
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    questions   Question[]
    games       Game[]
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt

    @@index([userId])
}

model Question {
    id        String       @id @default(uuid())
    quizId    String
    quiz      Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
    text      String
    imageUrl  String?
    type      QuestionType @default(SINGLE)
    options   Option[]
    answers   Answer[]
    createdAt DateTime     @default(now())
    updatedAt DateTime     @updatedAt

    @@index([quizId])
}

enum QuestionType {
    SINGLE
    MULTIPLE
}

model Option {
    id         String   @id @default(uuid())
    questionId String
    question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
    text       String
    isCorrect  Boolean
    createdAt  DateTime @default(now())

    @@index([questionId])
}

model Game {
    id        String   @id @default(uuid())
    code      String   @unique @db.VarChar(6)
    quizId    String
    quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
    hostId    String
    host      User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
    players   Player[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([quizId])
    @@index([hostId])
}

model Player {
    id       String @id @default(uuid())
    gameId   String
    game     Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
    userId   String?
    user     User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
    name     String
    avatar   String
    score    Int    @default(0)
    answers  Answer[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([gameId])
    @@index([userId])
}

model Answer {
    id         String   @id @default(uuid())
    playerId   String
    player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
    questionId String
    question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
    selected   String[]
    isCorrect  Boolean
    createdAt  DateTime @default(now())

    @@index([playerId])
    @@index([questionId])
}
