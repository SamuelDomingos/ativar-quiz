PORT=4001
DATABASE_URL=postgresql://admin:admin@localhost:5432/db_quiz?schema=public

JWT_SECRET=change-me-in-production

REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────
# STORAGE — escolha um provider abaixo
# ──────────────────────────────────────────
#
# Opção 1: Local (padrão, sem config extra)
#   Os arquivos ficam em ./uploads e são servidos em BASE_URL/uploads/...
#
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads